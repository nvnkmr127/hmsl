{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "http://127.0.0.1:8000",
    "distDir": "http://127.0.0.1:8000",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "HMS - Hospital Management",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true,
        "execute": true,
        "sidecar": true,
        "scope": [
          { "name": "binaries/php-x86_64-pc-windows-msvc", "sidecar": true }
        ]
      },
      "window": { "all": true },
      "notification": { "all": true }
    },
    "bundle": {
      "active": true,
      "targets": ["nsis"],
      "identifier": "com.hms.offline",
      "icon": ["icons/icon.ico", "icons/icon.png"],
      "externalBin": ["binaries/php"],
      "resources": [
        "../../app",
        "../../bootstrap",
        "../../config",
        "../../database/factories",
        "../../database/migrations",
        "../../database/seeders",
        "../../database/.gitignore",
        "../../resources",
        "../../routes",
        "../../storage",
        "../../public",
        "../../vendor",
        "../../artisan",
        "../../.env.offline",
        "../../composer.json",
        "php_bin"
      ],
      "windows": {
        "nsis": {
          "installMode": "currentUser",
          "license": "LICENSE.txt",
          "installerIcon": "icons/install.ico",
          "sidebarImage": "icons/sidebar.bmp",
          "headerImage": "icons/header.bmp"
        }
      }
    },
    "security": { "csp": null },
    "updater": { "active": false },
    "systemTray": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    },
    "windows": [
      {
        "label": "main",
        "title": "HMS - Hospital Management",
        "url": "about:blank",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "visible": true
      }
    ]
  }
}